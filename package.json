{
  "name": "mapmycode",
  "displayName": "MapMyCode — Algorithm & Data Structure Visualizer",
  "description": "Visualize data structures, algorithms, and codebases in real time. Step-by-step playback, interactive graphs, and more.",
  "version": "0.1.3",
  "publisher": "HimakarRaju",
  "icon": "media/extension-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/HimakarRaju/mapmycode.git"
  },
  "homepage": "https://github.com/HimakarRaju/mapmycode#readme",
  "bugs": {
    "url": "https://github.com/HimakarRaju/mapmycode/issues"
  },
  "files": [
    "dist",
    "python",
    "middleware",
    "media",
    "README.md",
    "CHANGELOG.md",
    "LICENSE*",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Visualization",
    "Education",
    "Debuggers"
  ],
  "keywords": [
    "algorithm visualization",
    "data structure visualization",
    "code visualization",
    "execution tracing",
    "interactive graphs",
    "codebase visualization",
    "VS Code extension"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mapmycode.configureApp",
        "title": "Setup Web App Tracing",
        "category": "MapMyCode",
        "icon": "$(gear)"
      },
      {
        "command": "mapmycode.configureApp",
        "title": "Setup Web App Tracing",
        "category": "MapMyCode",
        "icon": "$(gear)"
      },
      {
        "command": "mapmycode.openPanel",
        "title": "Open MapMyCode Panel",
        "category": "MapMyCode",
        "icon": "$(layout-panel)"
      },
      {
        "command": "mapmycode.visualize",
        "title": "Visualize Current File",
        "category": "MapMyCode",
        "icon": "$(play)"
      },
      {
        "command": "mapmycode.visualizeSelection",
        "title": "Visualize Selection",
        "category": "MapMyCode"
      },
      {
        "command": "mapmycode.openTemplates",
        "title": "Open Algorithm Templates",
        "category": "MapMyCode",
        "icon": "$(library)"
      },
      {
        "command": "mapmycode.visualizeApp",
        "title": "Visualize Web App",
        "category": "MapMyCode",
        "icon": "$(globe)"
      },
      {
        "command": "mapmycode.stopApp",
        "title": "Stop Visualized App",
        "category": "MapMyCode",
        "icon": "$(debug-stop)"
      },
      {
        "command": "mapmycode.exportHTML",
        "title": "Export Visualization as HTML",
        "category": "MapMyCode",
        "icon": "$(export)"
      },
      {
        "command": "mapmycode.exportJSON",
        "title": "Export Trace as JSON",
        "category": "MapMyCode",
        "icon": "$(file-code)"
      },
      {
        "command": "mapmycode.exportMarkdown",
        "title": "Export Trace as Mermaid.js Report",
        "category": "MapMyCode",
        "icon": "$(markdown)"
      },
      {
        "command": "mapmycode.visualizeCodebase",
        "title": "Visualize Codebase",
        "category": "MapMyCode",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "mapmycode.showDependencyNetwork",
        "title": "Open Dependency Network",
        "category": "MapMyCode",
        "icon": "$(references)"
      },
      {
        "command": "mapmycode.showCallGraph",
        "title": "Open Call Graph",
        "category": "MapMyCode",
        "icon": "$(graph-line)"
      },
      {
        "command": "mapmycode.refreshHistory",
        "title": "Refresh Trace History",
        "category": "MapMyCode",
        "icon": "$(refresh)"
      },
      {
        "command": "mapmycode.clearHistory",
        "title": "Clear Trace History",
        "category": "MapMyCode",
        "icon": "$(trash)"
      },
      {
        "command": "mapmycode.deleteHistoryEntry",
        "title": "Delete History Entry",
        "category": "MapMyCode",
        "icon": "$(trash)"
      },
      {
        "command": "mapmycode.clearHistory",
        "title": "Clear Trace History",
        "category": "MapMyCode",
        "icon": "$(trash)"
      },
      {
        "command": "mapmycode.deleteHistoryEntry",
        "title": "Delete History Entry",
        "category": "MapMyCode",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mapmycode",
          "title": "MapMyCode",
          "icon": "media/activity-bar.svg"
        }
      ]
    },
    "views": {
      "mapmycode": [
        {
          "id": "mapmycode.explore",
          "name": "Explore"
        },
        {
          "id": "mapmycode.history",
          "name": "Recent Traces"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "mapmycode.exportHTML",
          "when": "view == mapmycode.explore",
          "group": "navigation"
        },
        {
          "command": "mapmycode.exportJSON",
          "when": "view == mapmycode.explore",
          "group": "navigation"
        },
        {
          "command": "mapmycode.exportMarkdown",
          "when": "view == mapmycode.explore",
          "group": "navigation"
        },
        {
          "command": "mapmycode.openPanel",
          "when": "view == mapmycode.explore",
          "group": "navigation"
        },
        {
          "command": "mapmycode.refreshHistory",
          "when": "view == mapmycode.history",
          "group": "navigation"
        },
        {
          "command": "mapmycode.clearHistory",
          "when": "view == mapmycode.history",
          "group": "navigation"
        },
        {
          "command": "mapmycode.clearHistory",
          "when": "view == mapmycode.history",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "mapmycode.visualize",
          "when": "resourceLangId == javascript || resourceLangId == python || resourceLangId == typescript",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mapmycode.visualize",
          "when": "resourceLangId == javascript || resourceLangId == python || resourceLangId == typescript",
          "group": "mapmycode@1"
        },
        {
          "command": "mapmycode.visualizeSelection",
          "when": "editorHasSelection && (resourceLangId == javascript || resourceLangId == python || resourceLangId == typescript)",
          "group": "mapmycode@2"
        }
      ],
      "commandPalette": [
        {
          "command": "mapmycode.openPanel"
        },
        {
          "command": "mapmycode.visualize",
          "when": "resourceLangId == javascript || resourceLangId == python || resourceLangId == typescript"
        },
        {
          "command": "mapmycode.visualizeSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "mapmycode.openTemplates"
        },
        {
          "command": "mapmycode.visualizeApp"
        },
        {
          "command": "mapmycode.stopApp"
        },
        {
          "command": "mapmycode.exportHTML"
        },
        {
          "command": "mapmycode.exportJSON"
        },
        {
          "command": "mapmycode.exportMarkdown"
        },
        {
          "command": "mapmycode.visualizeCodebase"
        },
        {
          "command": "mapmycode.showDependencyNetwork"
        },
        {
          "command": "mapmycode.showCallGraph"
        },
        {
          "command": "mapmycode.refreshHistory"
        }
      ],
      "view/item/context": [
        {
          "command": "mapmycode.deleteHistoryEntry",
          "when": "view == mapmycode.history && viewItem == historyEntry"
        }
      ]
    },
    "configuration": {
      "title": "MapMyCode",
      "properties": {
        "mapmycode.nodePath": {
          "type": "string",
          "default": "",
          "description": "Custom path to Node.js executable. Leave empty to auto-detect."
        },
        "mapmycode.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to Python executable. Leave empty to auto-detect."
        },
        "mapmycode.timeout": {
          "type": "number",
          "default": 10000,
          "description": "Maximum execution time in milliseconds (default: 10000)."
        },
        "mapmycode.maxSteps": {
          "type": "number",
          "default": 5000,
          "description": "Maximum number of execution trace steps."
        },
        "mapmycode.defaultSpeed": {
          "type": "number",
          "default": 1,
          "minimum": 0.1,
          "maximum": 10,
          "description": "Default playback speed multiplier."
        },
        "mapmycode.appViz.startCommand": {
          "type": "string",
          "default": "python app.py",
          "description": "Custom command to start your web app. If empty, MapMyCode auto-generates a launcher script."
        },
        "mapmycode.appViz.appPort": {
          "type": "number",
          "default": 5000,
          "description": "Specific port to expose the web app on. Defaults to 5000 for Flask and 8000 for FastAPI."
        },
        "mapmycode.htmlExport.theme": {
          "type": "string",
          "enum": [
            "dark",
            "light"
          ],
          "default": "dark",
          "description": "Theme for HTML exports."
        },
        "mapmycode.htmlExport.customCSS": {
          "type": "string",
          "default": "",
          "description": "Custom CSS styles to inject into HTML exports."
        },
        "mapmycode.htmlExport.layoutDirection": {
          "type": "string",
          "enum": [
            "row",
            "column"
          ],
          "default": "row",
          "description": "Visual layout direction for HTML export: row (side-by-side) or column (vertical stack)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "package:vsix": "vsce package --allow-star-activation",
    "package:vsix:release": "vsce package --allow-star-activation --out mapmycode.vsix"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.70.0",
    "@vscode/vsce": "^3.9.1",
    "d3": "^7.9.0",
    "esbuild": "^0.28.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3"
  }
}
